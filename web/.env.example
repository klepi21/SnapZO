# WalletConnect / Reown — https://cloud.reown.com/ (create a project, copy the Project ID)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# In the Reown dashboard for this project, add to the allowlist / allowed domains:
#   http://localhost:3000
#   http://127.0.0.1:3000
# Otherwise you may see: "Origin http://localhost:3000 not found on Allowlist"

# WalletConnect is OFF by default (injected wallets only — no allowlist needed).
# Set to true only after allowlisting localhost AND setting PROJECT_ID above.
# NEXT_PUBLIC_ENABLE_WALLETCONNECT=true

# Optional: override MUSD token address on Mezo testnet (defaults to matsnet MUSD)
# NEXT_PUBLIC_MUSD_TOKEN_ADDRESS=0x...

# SnapZO backend (create post, feed, etc.) — default http://127.0.0.1:4000
# NEXT_PUBLIC_SNAPZO_API_URL=http://127.0.0.1:4000

# SnapZo pooled hub (UUPS proxy) + SNAP — set both to show the “SnapZo hub” panel on /earn
NEXT_PUBLIC_SNAPZO_HUB_ADDRESS=0x9Cd1C98aC5C4F68881dcC63Ded54Ddb239033BfD
NEXT_PUBLIC_SNAP_TOKEN_ADDRESS=0xCA1A5C01c533dDE957f0eFC79b25906b0187039D
#
# Relayer EOA (SERVER ONLY — put in web/.env.local, never commit a real key).
# 0x + 64 hex chars. Example shape only (invalid / do not use):
# RELAYER_PRIVATE_KEY=

# --------------------------------------------------------------------
# SnapZO backend — environment variables
# Copy this file to `.env` and fill in real values.
# --------------------------------------------------------------------

# HTTP server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/snapzo

# --------------------------------------------------------------------
# Mezo testnet (EVM)
# Docs: https://mezo.org/docs/developers/getting-started/
# --------------------------------------------------------------------
RPC_URL=https://rpc.test.mezo.org
CHAIN_ID=31611

# MUSD ERC-20 token address on Mezo testnet.
# Override with the official deployed address.
MUSD_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# Backend escrow / relayer wallet — holds MUSD for pay-to-reply escrow
# and signs refund transactions. Keep PRIVATE KEY secret.
ESCROW_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
ESCROW_PRIVATE_KEY=

# Optional: hub contract emitting unlock / tip / reply events to listen to.
# Leave empty if you only verify raw MUSD ERC-20 transfers.
HUB_CONTRACT_ADDRESS=

# --------------------------------------------------------------------
# IPFS (nft.storage)
# Get a token at https://nft.storage
# --------------------------------------------------------------------
NFT_STORAGE_TOKEN=

# --------------------------------------------------------------------
# Pay-to-Reply config
# --------------------------------------------------------------------
# Hours a creator has to respond before a refund is allowed.
REPLY_WINDOW_HOURS=24

# Refund cron schedule (default: every 5 minutes).
REFUND_CRON_SCHEDULE=*/5 * * * *

# --------------------------------------------------------------------
# On-chain verification tolerances
# --------------------------------------------------------------------
# Number of block confirmations required before accepting a tx.
TX_MIN_CONFIRMATIONS=1
# Token decimals (MUSD is 18).
MUSD_DECIMALS=18
